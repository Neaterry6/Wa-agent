    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "axios": "^1.16.1",
    "better-sqlite3": "^12.10.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "groq-sdk": "^1.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "octokit": "^5.0.5",
    "openai": "^6.38.0",
    "puppeteer": "^25.0.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
